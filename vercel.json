{
  "buildCommand": "vite build",
  "devCommand": "vite --port $PORT",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/stripe/checkout",
      "destination": "/api/stripe/checkout.cjs"
    },
    {
      "source": "/api/stripe/webhook",
      "destination": "/api/stripe/webhook.cjs"
    },
    {
      "source": "/api/stripe/portal",
      "destination": "/api/stripe/portal.cjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
